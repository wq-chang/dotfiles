#!/usr/bin/env python
# PYTHON_ARGCOMPLETE_OK

import asyncio
import json
import re
from argparse import ArgumentParser, Namespace
from dataclasses import dataclass
from pathlib import Path
from typing import IO, TypeAlias, TypedDict, Callable, cast
from urllib.error import HTTPError
from urllib.parse import quote
from urllib.request import Request, urlopen

import argcomplete

SOURCE_TYPES = ("git", "github-release", "pypi", "npm")
deps_file = Path(__file__).resolve().parents[1] / "deps-lock.json"

JSONDict: TypeAlias = dict[str, object]
JSONList: TypeAlias = list[object]


class SerializedGithubReleaseAsset(TypedDict):
    name: str
    url: str
    hash: str


class SerializedDependency(TypedDict, total=False):
    type: str
    url: str
    branchName: str
    rev: str
    tag: str
    hash: str
    sparseCheckout: list[str]
    name: str
    version: str
    assetPatterns: dict[str, str]
    assets: dict[str, SerializedGithubReleaseAsset]


@dataclass
class GithubReleaseAsset:
    name: str
    url: str
    hash: str


@dataclass
class DependencyAttributes:
    type: str = "git"
    url: str | None = None
    branchName: str | None = None
    rev: str | None = None
    tag: str | None = None
    hash: str | None = None
    sparseCheckout: list[str] | None = None
    name: str | None = None
    version: str | None = None
    assetPatterns: dict[str, str] | None = None
    assets: dict[str, GithubReleaseAsset] | None = None


def parse_dependency_attributes(data_json: SerializedDependency) -> DependencyAttributes:
    """
    Parse a serialized dependency dict from deps-lock.json into a DependencyAttributes object.

    Args:
        data_json: The serialized dependency mapping loaded from JSON.

    Returns:
        DependencyAttributes with typed fields; converts serialized release assets into GithubReleaseAsset objects when present.
    """
    assets_json = data_json.get("assets")
    assets = (
        {
            system: GithubReleaseAsset(
                name=asset["name"],
                url=asset["url"],
                hash=asset["hash"],
            )
            for system, asset in assets_json.items()
        }
        if assets_json is not None
        else None
    )

    return DependencyAttributes(
        type=data_json.get("type", "git"),
        url=data_json.get("url"),
        branchName=data_json.get("branchName"),
        rev=data_json.get("rev"),
        tag=data_json.get("tag"),
        hash=data_json.get("hash"),
        sparseCheckout=data_json.get("sparseCheckout"),
        name=data_json.get("name"),
        version=data_json.get("version"),
        assetPatterns=data_json.get("assetPatterns"),
        assets=assets,
    )


def serialize_release_asset(asset: GithubReleaseAsset) -> SerializedGithubReleaseAsset:
    """
    Convert a GithubReleaseAsset dataclass to a JSON-serializable mapping.
    """
    return {
        "name": asset.name,
        "url": asset.url,
        "hash": asset.hash,
    }


def clean_dict(dependency: DependencyAttributes) -> SerializedDependency:
    """
    Produce a serializable dict for a DependencyAttributes object, omitting None fields.

    Args:
        dependency: DependencyAttributes instance to serialize.

    Returns:
        A SerializedDependency mapping suitable for JSON output.
    """
    clean: SerializedDependency = {"type": dependency.type}
    if dependency.url is not None:
        clean["url"] = dependency.url
    if dependency.branchName is not None:
        clean["branchName"] = dependency.branchName
    if dependency.rev is not None:
        clean["rev"] = dependency.rev
    if dependency.tag is not None:
        clean["tag"] = dependency.tag
    if dependency.hash is not None:
        clean["hash"] = dependency.hash
    if dependency.sparseCheckout is not None:
        clean["sparseCheckout"] = dependency.sparseCheckout
    if dependency.name is not None:
        clean["name"] = dependency.name
    if dependency.version is not None:
        clean["version"] = dependency.version
    if dependency.assetPatterns is not None:
        clean["assetPatterns"] = dict(sorted(dependency.assetPatterns.items()))
    if dependency.assets is not None:
        clean["assets"] = {
            system: serialize_release_asset(asset)
            for system, asset in sorted(dependency.assets.items())
        }
    return clean


def load_data() -> dict[str, DependencyAttributes]:
    """
    Load locked dependency data from deps-lock.json into DependencyAttributes objects.

    Returns:
        A dict mapping dependency names to DependencyAttributes. Returns empty dict if file missing.
    """
    if not deps_file.exists():
        return {}

    with deps_file.open("r") as file:
        raw_data = cast(dict[str, SerializedDependency], json.load(file))
        return {key: parse_dependency_attributes(value) for key, value in raw_data.items()}


def dump_data(data: dict[str, DependencyAttributes]) -> None:
    """
    Write dependency data to deps-lock.json in a stable, sorted format.

    Args:
        data: Mapping of dependency names to DependencyAttributes to persist.
    """
    with deps_file.open("w") as file:
        sorted_data = dict(sorted(data.items()))
        json.dump({key: clean_dict(value) for key, value in sorted_data.items()}, file, indent=2)
        _ = file.write("\n")


async def run_command(command: list[str]) -> str:
    """
    Execute a subprocess command asynchronously and return its stdout.

    Args:
        command: The command and arguments to execute.

    Returns:
        Decoded stdout from the process.

    Raises:
        RuntimeError: if the subprocess exits with a non-zero return code.
    """
    process = await asyncio.create_subprocess_exec(
        *command, stdout=asyncio.subprocess.PIPE, stderr=asyncio.subprocess.PIPE
    )

    stdout, stderr = await process.communicate()

    if process.returncode != 0:
        raise RuntimeError(stderr.decode().strip())

    return stdout.decode().strip()


def fetch_json(url: str) -> JSONDict | JSONList:
    """
    Fetch and parse JSON from a URL using urllib, with GitHub-compatible Accept header.

    Args:
        url: The URL to request.

    Returns:
        Parsed JSON (dict or list).

    Raises:
        urllib.error.HTTPError: on HTTP errors.
    """
    request = Request(
        url,
        headers={
            "Accept": "application/vnd.github+json, application/json",
            "User-Agent": "mdep",
        },
    )

    with cast(IO[bytes], urlopen(request)) as response:
        return cast(JSONDict | JSONList, json.load(response))


async def fetch_json_async(url: str) -> JSONDict | JSONList:
    """
    Async wrapper around fetch_json that runs the request in a thread.

    Args:
        url: The URL to fetch.

    Returns:
        Parsed JSON (dict or list).
    """
    return await asyncio.to_thread(fetch_json, url)


def parse_github_repo_url(url: str) -> tuple[str, str]:
    """
    Extract owner and repository name from various GitHub repository URL formats.

    Args:
        url: GitHub URL or SSH/GIT spec.

    Returns:
        (owner, repo)

    Raises:
        ValueError: if the URL format is unsupported.
    """
    patterns = [
        r"^https://github\.com/(?P<owner>[^/]+)/(?P<repo>[^/]+?)(?:\.git)?/?$",
        r"^ssh://git@github\.com/(?P<owner>[^/]+)/(?P<repo>[^/]+?)(?:\.git)?/?$",
        r"^git@github\.com:(?P<owner>[^/]+)/(?P<repo>[^/]+?)(?:\.git)?$",
    ]

    for pattern in patterns:
        match = re.match(pattern, url)
        if match:
            return match.group("owner"), match.group("repo")

    raise ValueError(f"Unsupported GitHub repository URL: {url}")


def parse_mapping_args(raw_values: list[str], label: str) -> dict[str, str] | None:
    """
    Parse a list of key=value strings into a dict.

    Args:
        raw_values: List of strings of the form 'key=value'.
        label: Human-readable label used in error messages.

    Returns:
        A dict mapping keys to values, or None if raw_values is empty.
    """
    parsed: dict[str, str] = {}
    for raw_value in raw_values:
        key, separator, value = raw_value.partition("=")
        if separator == "" or key == "" or value == "":
            raise ValueError(f"Expected {label} in the form key=value, got: {raw_value}")

        parsed[key] = value

    return parsed or None


def normalize_release_version(tag: str, release_name: str | None = None) -> str:
    """
    Normalize a release version string, preferring a non-empty release name over the tag.

    Args:
        tag: The tag name (e.g., 'v1.2.3').
        release_name: Optional release title from GitHub.

    Returns:
        A normalized version string without a leading 'v' where applicable.
    """
    if release_name:
        stripped_name = release_name.strip()
        if stripped_name != "":
            return stripped_name.removeprefix("v")

    return tag.removeprefix("v")


async def get_default_git_branch_async(url: str) -> tuple[str, str]:
    """
    Resolve the default branch and its latest commit for a remote Git repository.

    Args:
        url: Repository URL.

    Returns:
        Tuple (rev, branch) where rev is the commit SHA and branch is branch name.

    Raises:
        RuntimeError: if unable to determine the default branch.
    """
    output = await run_command(["git", "ls-remote", "--symref", url, "HEAD"])

    branch_match = re.search(r"ref:\s+refs/heads/(?P<branch>[^\t]+)\tHEAD", output)
    rev_match = re.search(r"^(?P<rev>[0-9a-f]{40})\tHEAD$", output, re.MULTILINE)

    if branch_match is None or rev_match is None:
        raise RuntimeError(f"Unable to resolve the default branch for {url}")

    return rev_match.group("rev"), branch_match.group("branch")


async def get_latest_git_rev_async(url: str, branch: str | None) -> tuple[str, str]:
    """
    Get the latest commit SHA for the given branch (or default branch if None).

    Args:
        url: Repository URL.
        branch: Branch to query, or None to use default.

    Returns:
        Tuple (rev, branch).

    Raises:
        RuntimeError: if the commit cannot be resolved.
    """
    if branch is None:
        return await get_default_git_branch_async(url)

    output = await run_command(["git", "ls-remote", url, f"refs/heads/{branch}"])
    output_parts = output.split()
    if len(output_parts) < 2:
        raise RuntimeError(f"Unable to resolve the latest commit for {url}@{branch}")

    return output_parts[0], branch


def github_release_archive_url(url: str, tag: str) -> str:
    """
    Construct the URL to a release archive (.tar.gz) for a GitHub repository and tag.

    Args:
        url: Repository URL.
        tag: Release tag.

    Returns:
        Archive download URL.
    """
    base_url = url.removesuffix(".git").rstrip("/")
    return f"{base_url}/archive/refs/tags/{tag}.tar.gz"


def github_release_api_base_url(url: str) -> str:
    """
    Build the GitHub API base URL for a repository.

    Args:
        url: Repository URL.

    Returns:
        API base URL, e.g. 'https://api.github.com/repos/owner/repo'.
    """
    owner, repo = parse_github_repo_url(url)
    return f"https://api.github.com/repos/{owner}/{repo}"


async def get_github_release_data_async(url: str, tag: str | None) -> JSONDict | None:
    """
    Fetch release metadata from the GitHub Releases API for a given repo and optional tag.

    Args:
        url: Repository URL.
        tag: Release tag or None for latest.

    Returns:
        Parsed release JSON dict or None if not found (404).
    """
    api_base_url = github_release_api_base_url(url)
    endpoint = (
        f"{api_base_url}/releases/latest"
        if tag is None
        else f"{api_base_url}/releases/tags/{quote(tag, safe='')}"
    )

    try:
        return cast(JSONDict, await fetch_json_async(endpoint))
    except HTTPError as error:
        if error.code == 404:
            return None

        raise


async def get_latest_github_tag_async(url: str) -> str:
    """
    Query the repository tags API to determine the latest tag.

    Args:
        url: Repository URL.

    Returns:
        The latest tag name.

    Raises:
        RuntimeError: if no tags are available.
    """
    tags_data = cast(
        list[JSONDict],
        await fetch_json_async(f"{github_release_api_base_url(url)}/tags?per_page=1"),
    )
    if not tags_data:
        raise RuntimeError(f"Unable to resolve the latest tag for {url}")

    return cast(str, tags_data[0]["name"])


async def get_latest_github_release_tag_async(url: str) -> str:
    """
    Get the latest release tag, preferring the release entry and falling back to tags list.

    Args:
        url: Repository URL.

    Returns:
        A tag name string.
    """
    release_data = await get_github_release_data_async(url, None)
    if release_data is not None:
        tag_name = cast(str | None, release_data.get("tag_name"))
        if tag_name:
            return tag_name

    return await get_latest_github_tag_async(url)


def get_release_assets(release_data: JSONDict) -> list[JSONDict]:
    """
    Extract the 'assets' list from a GitHub release payload.

    Args:
        release_data: Parsed JSON for a release.

    Returns:
        List of asset dicts (may be empty).
    """
    return cast(list[JSONDict], release_data.get("assets", []))


def select_release_asset(
    release_assets: list[JSONDict], system: str, pattern: str
) -> JSONDict:
    """
    Choose a single release asset matching the provided regex pattern for a system.

    Args:
        release_assets: List of assets from a release.
        system: Logical system name used in the asset_patterns mapping.
        pattern: Regex pattern to match asset filenames.

    Returns:
        The matched asset dict.

    Raises:
        RuntimeError: if no assets match or multiple assets match.
    """
    matches = [
        asset
        for asset in release_assets
        if re.search(pattern, cast(str, asset["name"]))
    ]

    if not matches:
        raise RuntimeError(f"Unable to find a release asset for {system} matching {pattern!r}")

    if len(matches) > 1:
        matched_names = ", ".join(cast(str, asset["name"]) for asset in matches)
        raise RuntimeError(
            f"Multiple release assets matched {system} with pattern {pattern!r}: {matched_names}"
        )

    return matches[0]


async def prefetch_file_hash_async(url: str, unpack: bool = False) -> str:
    """
    Use 'nix store prefetch-file' to fetch a remote file and return its Nix hash.

    Args:
        url: URL to prefetch.
        unpack: Whether to unpack the archive before hashing.

    Returns:
        The Nix hash string.
    """
    command = ["nix", "store", "prefetch-file", "--json"]
    if unpack:
        command.append("--unpack")
    command.append(url)

    output = await run_command(command)
    data = cast(dict[str, str], json.loads(output))
    return data["hash"]


async def lock_release_asset_async(asset: JSONDict) -> GithubReleaseAsset:
    """
    Lock a single GitHub release asset by fetching its URL and computing its hash.

    Args:
        asset: Asset payload from the release JSON.

    Returns:
        GithubReleaseAsset with name, url, and resolved hash.
    """
    asset_url = cast(str, asset["browser_download_url"])
    return GithubReleaseAsset(
        name=cast(str, asset["name"]),
        url=asset_url,
        hash=await prefetch_file_hash_async(asset_url),
    )


async def lock_release_assets_async(
    release_data: JSONDict, asset_patterns: dict[str, str]
) -> dict[str, GithubReleaseAsset]:
    """
    Lock a set of GitHub release assets according to asset_patterns, returning a mapping by system.

    Args:
        release_data: Release JSON payload.
        asset_patterns: Mapping of system -> regex pattern.

    Returns:
        Mapping of system name to GithubReleaseAsset.
    """
    release_assets = get_release_assets(release_data)
    selected_assets = {
        system: select_release_asset(release_assets, system, pattern)
        for system, pattern in asset_patterns.items()
    }

    locked_assets = await asyncio.gather(
        *(lock_release_asset_async(asset) for asset in selected_assets.values())
    )

    return {
        system: locked_asset
        for system, locked_asset in zip(selected_assets.keys(), locked_assets, strict=True)
    }


async def get_git_hash_async(
    url: str,
    branch: str | None,
    rev: str,
    sparse_checkout: list[str] | None,
) -> str:
    """
    Compute a Nix fetchgit hash for a specific repository revision using 'nurl'.

    Args:
        url: Repository URL.
        branch: Branch name or None.
        rev: Commit SHA to lock.
        sparse_checkout: Optional list of sparse paths.

    Returns:
        The computed fetchgit hash.

    Raises:
        RuntimeError: if the hash cannot be extracted from nurl output.
    """
    command = ["nurl", url, rev, "-f", "fetchgit"]

    if branch:
        command.extend(["-A", "branchName", branch])

    if sparse_checkout:
        sparse_checkout_value = "[" + " ".join(f'"{entry}"' for entry in sparse_checkout) + "]"
        command.extend(["-a", "sparseCheckout", sparse_checkout_value])

    output = await run_command(command)
    hash_match = re.search(r'hash\s*=\s*"([^"]+)";', output)
    if hash_match is None:
        raise RuntimeError(f"Unable to extract a fetchgit hash from nurl output for {url}@{rev}")

    return hash_match.group(1)


async def resolve_git_dependency_async(
    url: str,
    branch: str | None,
    rev: str | None,
    sparse_checkout: list[str] | None,
) -> DependencyAttributes:
    """
    Resolve a git dependency by determining the revision and computing its hash.

    Args:
        url: Repository URL.
        branch: Optional branch name.
        rev: Optional explicit revision (commit SHA).
        sparse_checkout: Optional sparse checkout paths.

    Returns:
        DependencyAttributes containing resolved branch, rev, and hash.
    """
    latest_rev, resolved_branch = await get_latest_git_rev_async(url, branch)
    resolved_rev = rev or latest_rev
    hash_value = await get_git_hash_async(url, resolved_branch, resolved_rev, sparse_checkout)

    return DependencyAttributes(
        type="git",
        url=url,
        branchName=resolved_branch,
        rev=resolved_rev,
        hash=hash_value,
        sparseCheckout=sparse_checkout,
    )


async def resolve_github_release_dependency_async(
    url: str,
    tag: str | None,
    version: str | None,
    asset_patterns: dict[str, str] | None,
) -> DependencyAttributes:
    """
    Resolve a GitHub release dependency into concrete attributes.

    Args:
        url: Repository identifier or URL (e.g. "owner/repo" or full GitHub URL).
        tag: Specific tag to resolve. If None, the latest tag will be used.
        version: Optional override for the resolved version string.
        asset_patterns: If provided, lock and return release assets matching
            these glob patterns instead of a release archive hash.

    Returns:
        DependencyAttributes describing the resolved release. When
        asset_patterns is provided the returned attributes include `assets`
        and `assetPatterns`; otherwise they include a `hash` of the release
        archive suitable for reproducible fetching.

    Raises:
        RuntimeError: If asset_patterns is provided but the requested release
            (tag or latest) cannot be found.
    """
    release_data = await get_github_release_data_async(url, tag)

    if asset_patterns is not None:
        if release_data is None:
            requested = tag or "latest"
            raise RuntimeError(
                f"GitHub release assets require a real release. Unable to resolve {requested} for {url}"
            )

        resolved_tag = cast(str, release_data["tag_name"])
        resolved_version = version or normalize_release_version(
            resolved_tag, cast(str | None, release_data.get("name"))
        )
        assets = await lock_release_assets_async(release_data, asset_patterns)

        return DependencyAttributes(
            type="github-release",
            url=url,
            tag=resolved_tag,
            version=resolved_version,
            assetPatterns=asset_patterns,
            assets=assets,
        )

    if release_data is not None:
        resolved_tag = cast(str, release_data["tag_name"])
        resolved_version = version or normalize_release_version(
            resolved_tag, cast(str | None, release_data.get("name"))
        )
    else:
        resolved_tag = tag or await get_latest_github_tag_async(url)
        resolved_version = version or normalize_release_version(resolved_tag)

    hash_value = await prefetch_file_hash_async(github_release_archive_url(url, resolved_tag), unpack=True)

    return DependencyAttributes(
        type="github-release",
        url=url,
        tag=resolved_tag,
        version=resolved_version,
        hash=hash_value,
    )


async def get_pypi_source_async(package_name: str, version: str | None) -> tuple[str, str]:
    """
    Resolve a PyPI package and version to a source sdist URL and resolved version.

    Args:
        package_name: PyPI package name.
        version: Optional version string; if None the latest is used.

    Returns:
        Tuple (resolved_version, sdist_url).

    Raises:
        RuntimeError: if no source distribution is found for the resolved version.
    """
    resolved_version = version
    if resolved_version is None:
        package_data = cast(
            JSONDict, await fetch_json_async(f"https://pypi.org/pypi/{package_name}/json")
        )
        info = cast(JSONDict, package_data["info"])
        resolved_version = cast(str, info["version"])

    release_data = cast(
        JSONDict,
        await fetch_json_async(f"https://pypi.org/pypi/{package_name}/{resolved_version}/json"),
    )

    urls = cast(list[JSONDict], release_data["urls"])
    source_distribution = next(
        (entry for entry in urls if entry.get("packagetype") == "sdist"),
        None,
    )

    if source_distribution is None:
        raise RuntimeError(f"Unable to find a source distribution for {package_name}@{resolved_version}")

    return resolved_version, cast(str, source_distribution["url"])


async def resolve_pypi_dependency_async(
    package_name: str, version: str | None
) -> DependencyAttributes:
    """
    Resolve a PyPI dependency into DependencyAttributes including the sdist URL and hash.

    Args:
        package_name: PyPI package name.
        version: Optional version string.

    Returns:
        DependencyAttributes with type 'pypi', name, version, url, and hash.
    """
    resolved_version, source_url = await get_pypi_source_async(package_name, version)
    hash_value = await prefetch_file_hash_async(source_url)

    return DependencyAttributes(
        type="pypi",
        url=source_url,
        name=package_name,
        version=resolved_version,
        hash=hash_value,
    )


async def get_npm_source_async(package_name: str, version: str | None) -> tuple[str, str]:
    """
    Resolve an npm package and version to a tarball URL and resolved version.

    Args:
        package_name: npm package name (may include scope).
        version: Optional version; if None resolves 'latest'.

    Returns:
        Tuple (resolved_version, tarball_url).
    """
    encoded_name = quote(package_name, safe="")
    metadata_url = (
        f"https://registry.npmjs.org/{encoded_name}/latest"
        if version is None
        else f"https://registry.npmjs.org/{encoded_name}/{version}"
    )
    package_data = cast(JSONDict, await fetch_json_async(metadata_url))
    dist = cast(JSONDict, package_data["dist"])
    return cast(str, package_data["version"]), cast(str, dist["tarball"])


async def resolve_npm_dependency_async(
    package_name: str, version: str | None
) -> DependencyAttributes:
    """
    Resolve an npm dependency into DependencyAttributes with tarball URL and hash.

    Args:
        package_name: npm package name.
        version: Optional version.

    Returns:
        DependencyAttributes with type 'npm', name, version, url, and hash.
    """
    resolved_version, source_url = await get_npm_source_async(package_name, version)
    hash_value = await prefetch_file_hash_async(source_url)

    return DependencyAttributes(
        type="npm",
        url=source_url,
        name=package_name,
        version=resolved_version,
        hash=hash_value,
    )


async def resolve_dependency_async(
    dependency_type: str,
    source: str | None,
    branch: str | None,
    rev: str | None,
    sparse_checkout: list[str] | None,
    tag: str | None,
    package_name: str | None,
    version: str | None,
    asset_patterns: dict[str, str] | None,
) -> DependencyAttributes:
    """
    Resolve a dependency by dispatching to the appropriate resolver for its type.

    Args:
        dependency_type: One of 'git', 'github-release', 'pypi', or 'npm'.
        source: Source string (repo URL or package name) when applicable.
        branch: Git branch (for git sources).
        rev: Git revision (commit SHA) override.
        sparse_checkout: Optional sparse checkout paths for git.
        tag: GitHub release tag.
        package_name: Package name for PyPI/npm.
        version: Package or release version.
        asset_patterns: Asset pattern mapping for GitHub release assets.

    Returns:
        Resolved DependencyAttributes for the given dependency specification.

    Raises:
        ValueError: for missing required fields or unsupported types.
    """
    if dependency_type == "git":
        if source is None:
            raise ValueError("A Git dependency requires a repository URL.")

        return await resolve_git_dependency_async(source, branch, rev, sparse_checkout)

    if dependency_type == "github-release":
        if source is None:
            raise ValueError("A GitHub release dependency requires a repository URL.")

        return await resolve_github_release_dependency_async(source, tag, version, asset_patterns)

    if dependency_type == "pypi":
        resolved_name = package_name or source
        if resolved_name is None:
            raise ValueError("A PyPI dependency requires a package name.")

        return await resolve_pypi_dependency_async(resolved_name, version)

    if dependency_type == "npm":
        resolved_name = package_name or source
        if resolved_name is None:
            raise ValueError("An npm dependency requires a package name.")

        return await resolve_npm_dependency_async(resolved_name, version)

    raise ValueError(f"Unsupported dependency type: {dependency_type}")


async def update_dependency_async(data: dict[str, DependencyAttributes], dep_name: str) -> None:
    """
    Update a single dependency entry in-place by re-resolving its attributes.

    Args:
        data: The full dependency mapping (modified in-place).
        dep_name: The key of the dependency to update.

    Returns:
        None

    Raises:
        RuntimeError: if the dependency entry is missing required fields for its type.
    """
    dep = data[dep_name]

    if dep.type == "git":
        if dep.url is None:
            raise RuntimeError(f"Missing Git URL for dependency {dep_name}")

        latest_rev, resolved_branch = await get_latest_git_rev_async(dep.url, dep.branchName)
        if dep.rev == latest_rev and dep.hash is not None:
            return

        resolved_rev = latest_rev
        dep.rev = resolved_rev
        dep.branchName = resolved_branch
        dep.hash = await get_git_hash_async(
            dep.url, dep.branchName, resolved_rev, dep.sparseCheckout
        )
    elif dep.type == "github-release":
        if dep.url is None:
            raise RuntimeError(f"Missing GitHub release URL for dependency {dep_name}")

        latest_tag = await get_latest_github_release_tag_async(dep.url)
        if dep.assetPatterns is not None:
            if dep.tag == latest_tag and dep.assets is not None:
                return

            data[dep_name] = await resolve_github_release_dependency_async(
                dep.url, None, None, dep.assetPatterns
            )
        else:
            if dep.tag == latest_tag and dep.hash is not None:
                return

            data[dep_name] = await resolve_github_release_dependency_async(
                dep.url, None, None, None
            )
    elif dep.type == "pypi":
        if dep.name is None:
            raise RuntimeError(f"Missing PyPI package name for dependency {dep_name}")

        resolved_version, source_url = await get_pypi_source_async(dep.name, None)
        dep.version = resolved_version
        dep.url = source_url
        dep.hash = await prefetch_file_hash_async(source_url)
    elif dep.type == "npm":
        if dep.name is None:
            raise RuntimeError(f"Missing npm package name for dependency {dep_name}")

        resolved_version, source_url = await get_npm_source_async(dep.name, None)
        dep.version = resolved_version
        dep.url = source_url
        dep.hash = await prefetch_file_hash_async(source_url)
    else:
        raise RuntimeError(f"Unsupported dependency type for {dep_name}: {dep.type}")

    print(f"Updated {dep_name}")


def get_namespace_values(args: Namespace) -> dict[str, object]:
    """
    Convert an argparse Namespace into a plain dict with proper typing.

    Args:
        args: argparse Namespace instance.

    Returns:
        A dict mapping argument names to their values.
    """
    return cast(dict[str, object], vars(args))


def get_str_arg(args: Namespace, name: str) -> str:
    """
    Retrieve a required string argument from argparse Namespace, raising on type mismatch.

    Args:
        args: argparse Namespace.
        name: Argument name to retrieve.

    Returns:
        The string value for the argument.

    Raises:
        TypeError: if the value is not a string.
    """
    value = get_namespace_values(args)[name]
    if isinstance(value, str):
        return value

    raise TypeError(f"Expected {name} to be a string.")


def get_optional_str_arg(args: Namespace, name: str) -> str | None:
    """
    Retrieve an optional string argument from argparse Namespace (may be None).

    Args:
        args: argparse Namespace.
        name: Argument name to retrieve.

    Returns:
        The string value or None.

    Raises:
        TypeError: if the value is neither a string nor None.
    """
    value = get_namespace_values(args)[name]
    if value is None or isinstance(value, str):
        return value

    raise TypeError(f"Expected {name} to be a string or None.")


def get_str_list_arg(args: Namespace, name: str) -> list[str]:
    """
    Retrieve an argument expected to be a list of strings from argparse Namespace.

    Args:
        args: argparse Namespace.
        name: Argument name to retrieve.

    Returns:
        A list of strings.

    Raises:
        TypeError: if the value is not a list of strings.
    """
    value = get_namespace_values(args)[name]
    if not isinstance(value, list):
        raise TypeError(f"Expected {name} to be a list of strings.")

    items: list[str] = []
    for item in cast(list[object], value):
        if not isinstance(item, str):
            raise TypeError(f"Expected {name} to be a list of strings.")
        items.append(item)

    return items


def get_optional_str_list_arg(args: Namespace, name: str) -> list[str] | None:
    """
    Retrieve an optional argument expected to be a list of strings from argparse Namespace.

    Args:
        args: argparse Namespace.
        name: Argument name to retrieve.

    Returns:
        A list of strings or None.

    Raises:
        TypeError: if the value is neither None nor a list of strings.
    """
    value = get_namespace_values(args)[name]
    if value is None:
        return None

    if not isinstance(value, list):
        raise TypeError(f"Expected {name} to be a list of strings or None.")

    items: list[str] = []
    for item in cast(list[object], value):
        if not isinstance(item, str):
            raise TypeError(f"Expected {name} to be a list of strings or None.")
        items.append(item)

    return items


def get_arg_callback(args: Namespace) -> Callable[[Namespace], None] | None:
    """
    Extract a stored callback function from parsed argparse Namespace (used for subcommands).

    Args:
        args: argparse Namespace parsed from CLI.

    Returns:
        A callable taking a Namespace or None if not set.

    Raises:
        TypeError: if func is present but not callable.
    """
    value = get_namespace_values(args).get("func")
    if value is None:
        return None
    if callable(value):
        return cast(Callable[[Namespace], None], value)

    raise TypeError("Expected func to be callable.")


async def add_dependency_async(args: Namespace) -> None:
    """
    CLI handler for the 'add' subcommand: resolve a dependency and persist it to deps-lock.json.

    Args:
        args: Parsed argparse Namespace containing CLI options for the dependency.
    """
    asset_patterns = parse_mapping_args(get_str_list_arg(args, "asset_pattern"), "--asset-pattern")

    dependency = await resolve_dependency_async(
        dependency_type=get_str_arg(args, "type"),
        source=get_optional_str_arg(args, "source"),
        branch=get_optional_str_arg(args, "branch"),
        rev=get_optional_str_arg(args, "rev"),
        sparse_checkout=get_optional_str_list_arg(args, "sparse_checkout"),
        tag=get_optional_str_arg(args, "tag"),
        package_name=get_optional_str_arg(args, "package_name"),
        version=get_optional_str_arg(args, "version"),
        asset_patterns=asset_patterns,
    )

    data = load_data()
    dependency_name = get_str_arg(args, "name")
    data[dependency_name] = dependency
    dump_data(data)

    print(f"Dependency {dependency_name} was added successfully!")


async def update_dependencies_async(_args: Namespace) -> None:
    """
    CLI handler for the 'update' subcommand: update all dependencies by re-resolving their hashes/refs.

    Args:
        _args: Parsed argparse Namespace (unused).
    """
    data = load_data()
    tasks = [update_dependency_async(data, dep_name) for dep_name in data]
    _ = await asyncio.gather(*tasks)
    dump_data(data)

    print("Dependencies' hash and refs were updated successfully!")


def add_dependency(args: Namespace) -> None:
    """
    Synchronous wrapper that runs the add_dependency_async coroutine for CLI usage.

    Args:
        args: Parsed argparse Namespace for the 'add' command.
    """
    asyncio.run(add_dependency_async(args))


def update_dependencies(args: Namespace) -> None:
    """
    Synchronous wrapper that runs the update_dependencies_async coroutine for CLI usage.

    Args:
        args: Parsed argparse Namespace for the 'update' command.
    """
    asyncio.run(update_dependencies_async(args))


def main() -> None:
    """
    Command-line entry point for mdep. Parses arguments and dispatches subcommands.

    This sets up 'add' and 'update' subcommands and invokes the corresponding handlers.
    """
    parser = ArgumentParser(description="Manage locked Nix dependencies")
    subparsers = parser.add_subparsers(dest="action", help="Choose an action")

    parser_add = subparsers.add_parser("add", help="Add dependency")
    _ = parser_add.add_argument("name", type=str, help="Dependency key in deps-lock.json")
    _ = parser_add.add_argument(
        "source",
        nargs="?",
        type=str,
        help="Repository URL for git/github-release or package name for PyPI/npm",
    )
    _ = parser_add.add_argument(
        "-t",
        "--type",
        choices=SOURCE_TYPES,
        default="git",
        help="Dependency source type",
    )
    _ = parser_add.add_argument("-b", "--branch", type=str, help="Git branch name")
    _ = parser_add.add_argument("-r", "--rev", type=str, help="Git revision")
    _ = parser_add.add_argument("--tag", type=str, help="GitHub release tag")
    _ = parser_add.add_argument(
        "--asset-pattern",
        action="append",
        default=[],
        help="System-to-regex mapping for GitHub release assets, e.g. x86_64-linux=linux-x64\\.tar\\.gz",
    )
    _ = parser_add.add_argument(
        "-p",
        "--package-name",
        type=str,
        help="Package name for PyPI or npm dependencies",
    )
    _ = parser_add.add_argument("--version", type=str, help="Package version for GitHub release, PyPI, or npm")
    _ = parser_add.add_argument(
        "-s",
        "--sparse-checkout",
        nargs="+",
        type=str,
        help="Sparse checkout paths for git dependencies",
    )
    parser_add.set_defaults(func=add_dependency)

    parser_update = subparsers.add_parser("update", help="Update all dependencies")
    parser_update.set_defaults(func=update_dependencies)

    argcomplete.autocomplete(parser)
    args = parser.parse_args()
    argfunc = get_arg_callback(args)
    if argfunc is None:
        parser.print_help()
        return

    argfunc(args)


if __name__ == "__main__":
    main()
